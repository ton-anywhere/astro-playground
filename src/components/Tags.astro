---
const { tags } = Astro.props
---
<style>
  a {
    color: #00539F;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
  }

  .tag {
    margin: 0.25em;
    border: dotted 1px #a1a1a1;
    border-radius: .5em;
    padding: .5em 1em;
    font-size: 1.15em;
    background-color: #F8FCFD;
  }
</style>
<div class="tags">
  {tags.map((tag) => (
    <p class="tag"><a href={`/astro-playground/tags/${tag}`}>{tag}</a></p>
  ))}
</div>
